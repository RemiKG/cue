# ── Cue environment ─────────────────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`. The app runs fully without a
# key (on-device deterministic planner + local perception); a key activates the
# real Qwen Cloud reasoning path the moment it exists.

# Qwen Cloud (Alibaba DashScope, international endpoint). Plain sk- key, server-side only.
DASHSCOPE_API_KEY=

# The OpenAI-compatible base URL. Track-5 requires this to be visible in a repo
# code file — it lives in server/qwen.ts and defaults to the value below.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model routing (overridable). These are the IDs the design locks; change only if
# your DashScope account exposes different names.
QWEN_MODEL_VL=qwen3-vl-plus
QWEN_MODEL_PLAN=qwen3.7-plus
QWEN_MODEL_CONDUCT=qwen3.7-max
QWEN_MODEL_EMBED=text-embedding-v4
QWEN_MODEL_TTS=qwen3-tts-flash

# Port for the proxy/static server.
PORT=8787
